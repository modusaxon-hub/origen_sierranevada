# ========================================
# GEMINI API (AI Lab)
# ========================================
GEMINI_API_KEY=tu_api_key_aqui

# ========================================
# SUPABASE - CONFIGURACIÓN DE BASE DE DATOS
# ========================================
# Dashboard: https://supabase.com/dashboard/project/jbujautfyhiwbcpzbhor
VITE_SUPABASE_URL=https://jbujautfyhiwbcpzbhor.supabase.co
VITE_SUPABASE_ANON_KEY=tu_publishable_key_aqui

# Legacy keys (compatibilidad con Next.js - opcional)
NEXT_PUBLIC_SUPABASE_URL=https://jbujautfyhiwbcpzbhor.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_publishable_key_aqui

# ========================================
# WOMPI - PASARELA DE PAGOS
# ========================================

# Modo de operación:
# - true  = Sandbox (pruebas con tarjetas de prueba)
# - false = Producción (pagos reales)
VITE_WOMPI_SANDBOX=true

# Credenciales de SANDBOX (para testing)
# Obtén estas claves en: https://comercios.wompi.co (sección Credenciales Test)
VITE_WOMPI_PUBLIC_KEY_TEST=pub_test_XXXXXXXXXXXXXXXX
VITE_WOMPI_PRIVATE_KEY_TEST=prv_test_XXXXXXXXXXXXXXXX
VITE_WOMPI_EVENTS_SECRET=test_events_XXXXXXXXXXXXXXXX

# Credenciales de PRODUCCIÓN (¡NO llenar hasta estar listo para producción!)
# Obtén estas claves en: https://comercios.wompi.co (sección Credenciales Producción)
VITE_WOMPI_PUBLIC_KEY_PROD=
VITE_WOMPI_PRIVATE_KEY_PROD=

# ========================================
# INSTRUCCIONES DE USO
# ========================================
#
# 1. Copia este archivo y renómbralo a ".env"
#    cp .env.example .env
#
# 2. Reemplaza todos los valores "tu_*_aqui" con credenciales reales
#
# 3. NUNCA subas el archivo .env a Git
#    (ya está incluido en .gitignore)
#
# 4. Para cambiar a producción en Wompi:
#    - Cambia VITE_WOMPI_SANDBOX=false
#    - Completa las claves de producción
#    - Reinicia el servidor (npm run dev)
#
# Para más información sobre Wompi:
# Ver Documentation/Technical/WOMPI_SETUP.md
